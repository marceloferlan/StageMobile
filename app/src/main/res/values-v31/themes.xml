<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.StageMobile.Splash" parent="Theme.StageMobile">
        <!-- Background color of the splash screen (API 31+) -->
        <item name="android:windowSplashScreenBackground">@color/splash_bg</item>
        
        <!-- Icon to display on the splash screen (Using a transparent pixel to hide it) -->
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/transparent_pixel</item>
        
        <!-- Ensure the icon background matches the splash background -->
        <item name="android:windowSplashScreenIconBackgroundColor">@color/splash_bg</item>
        
        <!-- Standard window background (fallback) -->
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>
</resources>
